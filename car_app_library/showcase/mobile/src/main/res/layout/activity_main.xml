<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#10131A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/app_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#F4F7FB"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/app_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/mobile_subtitle"
            android:textColor="#AAB6C5"
            android:textSize="14sp" />

        <Button
            android:id="@+id/cycle_scenario_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/cycle_scenario_action_title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#1B2330"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/scenario_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mobile_active_scenario"
                android:textColor="#7DD3FC"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/scenario_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#F4F7FB"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/scenario_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#D6DEE8"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/connectivity_overview_title"
            android:textColor="#F4F7FB"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/connections_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1B2330"
            android:padding="16dp"
            android:textColor="#D6DEE8"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/media_center_title"
            android:textColor="#F4F7FB"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/media_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1B2330"
            android:padding="16dp"
            android:textColor="#D6DEE8"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/event_log_title"
            android:textColor="#F4F7FB"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/event_log_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1B2330"
            android:padding="16dp"
            android:textColor="#D6DEE8"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/reconnect_flow_title"
            android:textColor="#F4F7FB"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/reconnect_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:background="#1B2330"
            android:padding="16dp"
            android:textColor="#D6DEE8"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
